# =====================================================
# Coinbase CDP credentials (CDP モードで CDP 管理ウォレットを使う場合)
# =====================================================
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
CDP_ACCOUNT_NAME=ap2-buyer

# =====================================================
# ローカル EVM 鍵モード (CDP を使わない場合)
# 設定すると CDP 環境変数より優先される
# =====================================================
# EVM_PRIVATE_KEY=0x...

# =====================================================
# x402 ネットワーク / ファシリテータ
# テストネット (Base Sepolia) は x402.org の facilitator が無料で使える
# =====================================================
X402_NETWORK=base-sepolia
X402_FACILITATOR_URL=https://x402.org/facilitator

# =====================================================
# マーチャント側の受取アドレス (x402_server を起動するときに使用)
# =====================================================
MERCHANT_PAY_ADDRESS=0x0000000000000000000000000000000000000000

# =====================================================
# クライアント側 (x402_purchase) が叩く paywall URL
# =====================================================
MERCHANT_PAYWALL_URL=http://localhost:4021/merchant/checkout
